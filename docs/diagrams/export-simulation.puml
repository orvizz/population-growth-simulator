@startuml export-simulation

skinparam defaultFontName Liberation Sans
skinparam defaultFontSize 10
skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceMessageAlign left

skinparam participant {
  BorderColor #0056A0
  BackgroundColor #D6E8F7
  FontColor #003087
  FontStyle bold
}
skinparam actor {
  BorderColor #8B4513
  BackgroundColor #F5E6D3
  FontColor #8B4513
  FontStyle bold
}
skinparam database {
  BorderColor #5a7a3a
  BackgroundColor #E6F0D8
  FontColor #3a5a1a
}
skinparam note {
  BorderColor #aaaaaa
  BackgroundColor #FFFDE7
  FontSize 9
}

actor       "User"       as user
participant "Frontend"   as frontend
participant "Controller" as ctrl
participant "Service"    as svc
participant "Repository" as repo
database    "PostgreSQL" as db

user     ->  frontend : 1. Click "Export" on a saved simulation

frontend ->  ctrl     : 2. GET /v1/simulations/{id}/export\n   Authorization: Bearer <token>

note over ctrl
  3. Validate JWT → resolve user_id
end note

ctrl ->  svc  : 4. export(sim_id, user_id)
svc  ->  repo : 5. get_by_id(sim_id)
repo ->  db   : 6. SELECT simulation_runs WHERE id = ?
db   --> repo : 7. SimulationRun row
repo --> svc  : 8. ORM object

alt simulation not found
  svc --> ctrl : raise HTTP 404
  ctrl --> frontend : 404 Not Found
  frontend --> user : Show error
else not owner
  note over svc
    9. Ownership check: run.user_id == user_id
  end note
  svc --> ctrl : raise HTTP 403
  ctrl --> frontend : 403 Forbidden
  frontend --> user : Show error
else authorised
  note over svc
    10. Build export payload:
        {format_version, name, stochastic,
         matrix_id, matrix_ids, initial_vector,
         n_steps, random_seed, stage_names,
         result_history, exported_at}
  end note
  svc  --> ctrl     : 11. export dict
  ctrl --> frontend : 12. 200 JSON payload
  frontend --> user : 13. Trigger browser file download\n    Saved as <name>.json
end

@enduml
