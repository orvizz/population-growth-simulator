@startuml branch-strategy

skinparam defaultFontName Liberation Sans
skinparam defaultFontSize 10
skinparam shadowing false
skinparam backgroundColor white

skinparam sequence {
  ArrowColor #003087
  ActorBorderColor #003087
  LifeLineBorderColor #003087
  ParticipantBorderColor #003087
  ParticipantBackgroundColor #EEF3FA
  ParticipantFontColor #003087
  ParticipantFontStyle bold
  BoxBorderColor #003087
  BoxBackgroundColor #F8FBFF
}

skinparam note {
  BackgroundColor #FFF9E6
  BorderColor #C8A400
  FontColor #555555
}

skinparam arrow {
  Color #003087
  FontColor #555555
  FontSize 9
}

participant "dev\n (protected)" as dev
participant "feature/<topic>\nor fix/<topic>" as feature
participant "Pull Request" as pr
participant "GitHub Actions\n(CI / CD)" as actions
participant "ci.yml" as ci
participant "Deployment" as deply

dev -> feature : branch off dev\n(git checkout -b feature/...)
feature -> feature : implement + write tests
feature -> pr : open pull request\ntargets dev
pr -> actions : trigger CI pipeline
actions -> ci : trigger ci.yml
ci -> ci : unit tests \n→ integration tests\n→ coverage
ci -> ci : e2e tests
actions -> pr : CI passes ✓
pr -> pr : request code review
pr -> dev : merge to dev\n(squash or merge commit)
dev -> deply : trigger deploy \nstaging environment
deply -> deply : deploy staging
dev -> dev : test the changes in the \nstaging environment \n (fix bugs)
dev -> pr : open pr targets main
pr -> actions : trigger ci.yml

actions -> actions : unit tests \n→ integration tests\n→ coverage
actions -> actions : e2e tests
actions -> pr : CI passes ✓
pr -> pr : request code review

@enduml
