@startuml use-cases-auth

skinparam defaultFontName Liberation Sans
skinparam defaultFontSize 11
skinparam shadowing false
skinparam backgroundColor white

skinparam usecase {
  BorderColor #003087
  BackgroundColor #EEF3FA
  FontColor #003087
}
skinparam actor {
  BorderColor #003087
  BackgroundColor white
  FontColor #333333
}
skinparam rectangle {
  BorderColor #003087
  BackgroundColor white
}
skinparam arrow {
  Color #333333
  FontColor #555555
  FontSize 9
}

left to right direction

actor "Visitor" as visitor
actor "Registered\nUser" as user

visitor <|-- user

rectangle "Authentication" {
  (Register User) as UC01
  (Log In) as UC02
  (Log Out) as UC03
}

visitor --> UC01
visitor --> UC02
user --> UC03

@enduml
