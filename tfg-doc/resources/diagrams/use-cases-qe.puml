@startuml use-cases-qe

skinparam defaultFontName Liberation Sans
skinparam defaultFontSize 11
skinparam shadowing false
skinparam backgroundColor white

skinparam usecase {
  BorderColor #003087
  BackgroundColor #EEF3FA
  FontColor #003087
}
skinparam actor {
  BorderColor #003087
  BackgroundColor white
  FontColor #333333
}
skinparam rectangle {
  BorderColor #003087
  BackgroundColor white
}
skinparam arrow {
  Color #333333
  FontColor #555555
  FontSize 9
}

left to right direction

actor "Registered\nUser" as user

rectangle "Quasi-Extinction Analysis" {
  (Run Quasi-Extinction\nAnalysis) as UC19
  (Configure\nExtinction Stages) as UC20
}

user --> UC19
user --> UC20

UC20 .> UC19 : <<extends>>

@enduml
