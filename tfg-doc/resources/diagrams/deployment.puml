@startuml deployment

skinparam defaultFontName Liberation Sans
skinparam defaultFontSize 10
skinparam shadowing false
skinparam backgroundColor white
skinparam linetype ortho

skinparam node {
  BorderColor #003087
  BackgroundColor #EEF3FA
  FontColor #003087
  FontStyle bold
}

skinparam database {
  BorderColor #003087
  BackgroundColor #D6E4F0
  FontColor #003087
  FontStyle bold
}

skinparam actor {
  BorderColor #003087
  BackgroundColor #D6E4F0
  FontColor #003087
  FontStyle bold
}

skinparam arrow {
  Color #333333
  FontColor #555555
  FontSize 9
}

actor "Browser" as browser

node "Docker Host" {

  node "frontend\nShiny for Python" as frontend {
    [Shiny app\n:8080]
  }

  node "api\nFastAPI + uvicorn" as api {
    [REST API\n:8000]
  }

  node "db\npostgres:16-alpine" as db {
    [PostgreSQL\n:5432 (container)\n:5435 (host)]
  }

  database "postgres_data\n(named volume)" as vol

}

browser --> frontend : HTTP :8080
browser --> api : HTTP :8000\n(Swagger UI)
frontend --> api : HTTP REST\n:8000
api --> db : SQLAlchemy ORM\nTCP :5432
db --> vol : persists data

note right of db
  host-side port: 5435
  container port: 5432
  docker-compose.yml overrides
  POSTGRES_PORT=5432 inside containers
end note

@enduml
